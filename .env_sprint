# Docker Compose Project Name
COMPOSE_PROJECT_NAME=cubejs

# Cube Store Version
CUBESTORE_VERSION=v1.5.15

# Cube Store Router Configuration
CUBESTORE_ROUTER_META_PORT=9999
CUBESTORE_ROUTER_META_ADDR=cubestore_router:9999

# Cube Store Worker Configuration
CUBESTORE_WORKER_PORT=9001
CUBESTORE_WORKERS=cubestore_worker_1:9001,cubestore_worker_2:9001,cubestore_worker_3:9001,cubestore_worker_4:9001,cubestore_worker_5:9001,cubestore_worker_6:9001,cubestore_worker_7:9001,cubestore_worker_8:9001

# Cube Store Data Directory
CUBESTORE_REMOTE_DIR=/cube/data

# Cube.js Configuration
CUBEJS_VERSION=v1.5.15

CUBEJS_CUBESTORE_HOST=cubestore_router
CUBEJS_CUBESTORE_PORT=3030

CUBEJS_DB_HOST=mongobi
CUBEJS_DB_PORT=3307
CUBEJS_DB_USER=regology-admin
CUBEJS_DB_PASS='r3gul@t10n$'
CUBEJS_DB_NAME=RegHub
CUBEJS_DB_TYPE=mongobi

CUBEJS_API_SECRET=426b6efb864d8b5024736b2c7318c98e5d20a3b0da88e68d150f9f8f47419162035a2a99e6f87f813f79d333938bb310360334b594a4cc69b8fbe30e45e14d9e

CUBEJS_DEV_MODE=true
CUBEJS_DB_SSL=true
CUBEJS_DB_SSL_REJECT_UNAUTHORIZED=false

CUBEJS_CACHE_AND_QUEUE_DRIVER=memory
CUBEJS_REFRESH_WORKER=true

CUBEJS_SCHEMAS_PATH=/cube/conf/schema
CUBEJS_SCHEMA_PATH=schema

CUBEJS_DEFAULT_API_SCOPES=graphql,meta,data,jobs

# Query / refresh tuning
CUBEJS_CONCURRENCY=10
CUBEJS_DB_QUERY_TIMEOUT=20m
CUBEJS_REFRESH_WORKER_CONCURRENCY=2
CUBEJS_SCHEDULED_REFRESH_CONCURRENCY=1
CUBEJS_MAX_REFRESH_TENANTS=5

# MongoDB Connection String
MONGOHQ_URL=mongodb://regology-admin:r3gul%40t10n%24@db1:27017,db2:27018,db3:27019/RegHub?replicaSet=regology&authSource=admin

CUBEJS_LOG_LEVEL=info